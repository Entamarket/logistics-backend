{
  "info": {
    "_postman_id": "8f4c2a10-9b3e-4d1f-a7c2-5e6f708192a3",
    "name": "Logistics API",
    "description": "Logistics backend REST API. Folders mirror `src/modules/*`.\n\nAuth uses httpOnly cookie `token` on login.\n\n**Postman:** enable **Cookies** for the domain. Run **Login** (in `auth`) first.\n\n**WebSocket:** `ws://{{baseUrl}}/ws?token=<jwt>` — use **Get WS token** in `auth` while logged in.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000" },
    { "key": "shipmentId", "value": "" },
    { "key": "notificationId", "value": "" },
    { "key": "riderId", "value": "" }
  ],
  "item": [
