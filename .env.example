# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/logistics

# JWT / session secrets (use strong random values in production)
JWT_SECRET=
SESSION_SECRET=

# Comma-separated allowed browser origins (e.g. http://localhost:3000)
CORS_ORIGINS=http://localhost:3000

# Server-side Google Maps: enable Geocoding API + Distance Matrix API on this key.
# Restrict by IP or use a separate server key from the frontend Maps JS key.
GOOGLE_MAPS_API_KEY=

# Paystack (https://dashboard.paystack.com) — test keys for development
PAYSTACK_SECRET_KEY=sk_test_
PAYSTACK_PUBLIC_KEY=pk_test_
